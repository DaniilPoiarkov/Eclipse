{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "description": "Eclipse MCP server",
  "name": "io.github.DaniilPoiarkov/Eclipse",
  "version": "0.1.5-beta",
  "packages": [
    {
      "registryType": "nuget",
      "identifier": "Eclipse",
      "version": "0.1.5-beta",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [],
      "environmentVariables": [
        {
          "name": "ECLIPSE_API_TOKEN",
          "value": "{eclipse_api_token}",
          "variables": {
            "eclipse_api_token": {
              "description": "API token for authenticating with Eclipse services.",
              "isRequired": true,
              "isSecret": true
            }
          }
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/DaniilPoiarkov/Eclipse",
    "source": "github"
  }
}
